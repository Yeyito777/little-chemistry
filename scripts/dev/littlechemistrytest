#!/usr/bin/env bash
# littlechemistrytest — test and package a worktree without launching or deploying.
#
# Usage:
#   littlechemistrytest <worktree>
#   littlechemistrytest <worktree> --tests <JUnit-pattern>
#
# This never launches Minecraft or modifies the external Prism instance.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
# shellcheck source=./worktree-common.sh
source "$SCRIPT_DIR/worktree-common.sh"

INPUT="${1:-}"
[[ -n "$INPUT" ]] || worktree_die "Usage: littlechemistrytest <worktree> [--tests <JUnit-pattern>]"
shift

TEST_PATTERN=""
if [[ $# -gt 0 ]]; then
  [[ "${1:-}" == "--tests" && $# -eq 2 && -n "${2:-}" ]] ||
    worktree_die "Only --tests <JUnit-pattern> is supported; invoke Gradle directly for other options"
  TEST_PATTERN="$2"
fi

WORKTREE_DIR="$(resolve_worktree_dir "$INPUT")"
[[ -d "$WORKTREE_DIR" ]] || worktree_die "Not found: $WORKTREE_DIR"
is_registered_worktree "$WORKTREE_DIR" || worktree_die "Not a registered worktree: $WORKTREE_DIR"
[[ -f "$WORKTREE_DIR/build.gradle" ]] || worktree_die "No build.gradle in $WORKTREE_DIR"

WT_NAME="$(basename "$WORKTREE_DIR")"

printf '\n  littlechemistrytest — %s\n  %s\n\n' "$WT_NAME" "$WORKTREE_DIR"

prepare_gradle_worktree "$WORKTREE_DIR"

# Excluding installToPrism is deliberate defense in depth: even if a developer
# adds local.properties manually, validation must not replace the live mod JAR.
if [[ -n "$TEST_PATTERN" ]]; then
  (cd "$WORKTREE_DIR" && ./gradlew --no-daemon --console=plain clean test \
    --tests "$TEST_PATTERN" -x installToPrism)
else
  (cd "$WORKTREE_DIR" && ./gradlew --no-daemon --console=plain clean build \
    -x installToPrism)
fi

printf '\n  ✓ Worktree validation passed; Prism was not modified.\n'
if [[ -n "$TEST_PATTERN" ]]; then
  printf '  Filtered test: %s\n' "$TEST_PATTERN"
else
  printf '  JAR: %s/build/libs/little-chemistry-*.jar\n' "$WORKTREE_DIR"
fi
printf '  Launch Minecraft manually when ready for in-game testing.\n\n'
